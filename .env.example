# App
ENVIRONMENT=development

# Database
POSTGRES_USER=signalyst
POSTGRES_PASSWORD=signalyst
POSTGRES_DB=signalyst_agent
DATABASE_URL=postgresql+asyncpg://signalyst:signalyst@localhost:5432/signalyst_agent

# Redis
REDIS_URL=redis://localhost:6379

# API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
FRED_API_KEY=your-fred-api-key
EIA_API_KEY=your-eia-api-key
TABPFN_TOKEN=your-tabpfn-token
TABPFN_CLIENT_CI_MODE=1

# GPR data (optional overrides)
GPR_DATA_URL=
GPR_CACHE_TTL_HOURS=

# Sentry (optional)
SENTRY_DSN=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
